# 可选：在此配置 API Key，也可在前端页面输入
DASHSCOPE_API_KEY=your_api_key_here
# Gemini 可选：优先读取 GEMINI_API_KEY，未设置时回退 GOOGLE_API_KEY
# GEMINI_API_KEY=your_gemini_api_key_here
# GOOGLE_API_KEY=your_google_api_key_here
# Volcengine 可选：即梦AI（视觉）鉴权 AK/SK
# VOLCENGINE_ACCESS_KEY=your_volcengine_access_key
# VOLCENGINE_SECRET_KEY=your_volcengine_secret_key
# 服务端口，默认 3000
PORT=3000
# 可选：图生图上传临时文件对外访问域名（火山引擎拉取图片必须可公网访问）
# 本地开发若使用 localhost 会被火山拒绝，需配置为公网地址（例如反向代理/隧道域名）
# PUBLIC_BASE_URL=https://your-public-domain.com

# 可选：CORS 白名单（逗号分隔），例如：
# CORS_ORIGIN=http://localhost:3000,https://your-domain.com
# 不设置则不限制（保持兼容）。
# CORS_ORIGIN=

# 可选：上游 DashScope 请求超时（毫秒），默认 120000
# DASHSCOPE_TIMEOUT_MS=120000
# 可选：上游 Gemini 请求超时（毫秒），默认 180000
# GEMINI_TIMEOUT_MS=180000
# 可选：上游 Volcengine 请求超时（毫秒），默认 180000
# VOLCENGINE_TIMEOUT_MS=180000
# 可选：Volcengine 视觉域名与签名参数
# VOLCENGINE_HOST=visual.volcengineapi.com
# VOLCENGINE_REGION=cn-north-1
# VOLCENGINE_SERVICE=cv
# 可选：即梦 4.0/4.6 req_key（文档固定值）
# VOLCENGINE_JIMENG_40_REQ_KEY=jimeng_t2i_v40
# VOLCENGINE_JIMENG_46_REQ_KEY=jimeng_seedream46_cvtob
# 可选：任务轮询参数
# VOLCENGINE_MAX_POLL_ATTEMPTS=90
# VOLCENGINE_POLL_INTERVAL_MS=2000

# 可选：API 速率限制（按 IP，简单内存实现）
# RATE_LIMIT_WINDOW_MS=60000
# RATE_LIMIT_MAX=30

# 可选：调试日志开关（true/1 开启）
# DEBUG=false
